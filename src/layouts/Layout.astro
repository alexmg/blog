---
import "../styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/consts";
import Seo from "@/components/Seo.astro";
import { Font } from "astro:assets";

interface Props {
  title?: string;
  id?: string;
  description?: string;
}

const { title = SITE.title, description = SITE.description, id } = Astro.props;
const path = Astro.url.pathname;
const pageTitle = path === "/" ? title : `${title} | ${SITE.title}`;
---
<!doctype html>
<html lang="en" class="font-display-swap h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>

    <Seo {...{ title, description, id }} />

    <Font cssVariable="--font-cabin" preload />
    <Font cssVariable="--font-nunito" preload />
    <Font cssVariable="--font-inconsolata" preload />

    <!-- Prevent flash by applying theme immediately -->
    <script is:inline>
      // Apply theme as early as possible to prevent flash
      const savedTheme = localStorage.getItem("theme");
      if (
        savedTheme === "dark" ||
        (!savedTheme &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>
  </head>
  <body
    class="flex min-h-full flex-col bg-[#f3f8f9] text-[#163642] transition-colors duration-200 dark:bg-[#071822] dark:text-[#c2dbe0]"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 -z-10 overflow-hidden"
    >
      <div
        class="absolute top-28 right-[-62%] h-56 w-152 bg-[radial-gradient(ellipse_at_center,rgba(222,139,58,0.16)_0%,rgba(222,139,58,0.08)_32%,rgba(222,139,58,0)_76%)] sm:top-20 sm:right-[-48%] sm:h-72 sm:w-184 lg:top-14 lg:right-[-34%] lg:h-80 lg:w-216 xl:top-12 xl:right-[-24%] xl:h-96 xl:w-264 2xl:top-10 2xl:right-[-18%] 2xl:h-112 2xl:w-312 dark:bg-[radial-gradient(ellipse_at_center,rgba(222,139,58,0.14)_0%,rgba(222,139,58,0.07)_30%,rgba(222,139,58,0)_74%)]"
      ></div>
      <div
        class="absolute top-[18%] left-[-28%] h-136 w-96 -rotate-12 bg-[radial-gradient(ellipse_at_center,rgba(63,211,198,0.14)_0%,rgba(63,211,198,0.06)_34%,rgba(63,211,198,0)_78%)] sm:left-[-22%] sm:h-152 sm:w-md lg:top-[20%] lg:left-[-16%] lg:h-168 lg:w-120 xl:left-[-12%] xl:h-192 xl:w-lg 2xl:left-[-10%] 2xl:h-216 2xl:w-136 dark:bg-[radial-gradient(ellipse_at_center,rgba(63,211,198,0.16)_0%,rgba(63,211,198,0.07)_34%,rgba(63,211,198,0)_76%)]"
      >
        <div class="h-full w-full bg-[linear-gradient(to_bottom,rgba(7,24,34,0)_0%,rgba(7,24,34,0.06)_62%,rgba(7,24,34,0.18)_100%)] dark:bg-[linear-gradient(to_bottom,rgba(7,24,34,0)_0%,rgba(7,24,34,0.08)_62%,rgba(7,24,34,0.22)_100%)]"></div>
      </div>

    </div>

    <Header />

<main class="relative grow isolate">                                                                                                                                          
   <div                                                                                                                                                                        
     aria-hidden="true"                                                                                                                                                        
     class="pointer-events-none absolute inset-0 -z-10 overflow-hidden"                                                                                                       
   >                                                                                                                                                                           
     <div class="absolute inset-0 opacity-[0.4] dark:opacity-[0.16]">                                                                                                          
       <div                                                                                                                                                                    
         class="h-full w-full bg-[linear-gradient(rgba(148,170,176,0.25)_1px,transparent_1px),linear-gradient(90deg,rgba(148,170,176,0.25)_1px,transparent_1px)]               
│    dark:bg-[linear-gradient(rgba(63,211,198,0.15)_1px,transparent_1px),linear-gradient(90deg,rgba(63,211,198,0.15)_1px,transparent_1px)] bg-size-[48px_48px]"                      
       ></div>                                                                                                                                                                 
     </div>                                                                                                                                                                    
   </div> 
      <div class="container-base relative">
        <!-- Content goes here -->
        <slot />
      </div>
    </main>

    <Footer />

    <script src="@/assets/theme-switcher.js"></script>
  </body>
</html>
