---
import "../styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/consts";
import Seo from "@/components/Seo.astro";
import Fonts from "@/components/Fonts.astro";

interface Props {
  title?: string;
  id?: string;
  description?: string;
}

const { title = SITE.title, description = SITE.description, id } = Astro.props;
const path = Astro.url.pathname;
const pageTitle = path === "/" ? title : `${title} | ${SITE.title}`;
---
<!doctype html>
<html lang="en" class="font-display-swap h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>

    <Seo {...{ title, description, id }} />

    <Fonts />

    <!-- Prevent flash by applying theme immediately -->
    <script is:inline>
      // Apply theme as early as possible to prevent flash
      const savedTheme = localStorage.getItem("theme");
      if (
        savedTheme === "dark" ||
        (!savedTheme &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>
  </head>
  <body
    class="flex min-h-full flex-col bg-[#f3f8f9] text-[#163642] transition-colors duration-200 dark:bg-[#071822] dark:text-[#c2dbe0]"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 -z-10 overflow-hidden"
    >
      <div
        class="absolute -top-28 right-[-10%] h-[32rem] w-[32rem] rounded-full bg-[radial-gradient(circle,rgba(222,139,58,0.22)_0%,rgba(222,139,58,0)_72%)] dark:bg-[radial-gradient(circle,rgba(222,139,58,0.2)_0%,rgba(222,139,58,0)_70%)]"
      ></div>
      <div
        class="absolute top-[20%] left-[-12%] h-[30rem] w-[30rem] rounded-full bg-[radial-gradient(circle,rgba(63,211,198,0.18)_0%,rgba(63,211,198,0)_72%)] dark:bg-[radial-gradient(circle,rgba(63,211,198,0.2)_0%,rgba(63,211,198,0)_70%)]"
      ></div>
      <div class="absolute inset-0 opacity-[0.12] dark:opacity-[0.16]">
        <div
          class="h-full w-full bg-[linear-gradient(rgba(63,211,198,0.15)_1px,transparent_1px),linear-gradient(90deg,rgba(63,211,198,0.15)_1px,transparent_1px)] bg-[size:48px_48px]"
        ></div>
      </div>
    </div>

    <Header />

    <main class="flex-grow">
      <div class="container-base relative">
        <!-- Content goes here -->
        <slot />
      </div>
    </main>

    <Footer />

    <script src="@/assets/theme-switcher.js"></script>
  </body>
</html>
