---
import Gradient from "@/components/Gradient.astro";
import Layout from "@/layouts/Layout.astro";
import { getAllTagsWithCount, type TagWithCount } from "@/utils/data-utils";

const allTags: TagWithCount[] = await getAllTagsWithCount();
---

<Layout title="Post Tags">
  <div class="py-6">
    <h1 class="font-heading mb-2 text-2xl font-bold">
      <Gradient>Post Tags</Gradient>
    </h1>
    <p class="mb-8 text-sm tracking-wide text-[#537884] dark:text-[#7caab2]">
      {allTags.length} tag{allTags.length !== 1 ? "s" : ""} across all posts
    </p>

    <div class="flex flex-wrap gap-3">
      {
        allTags.map((tag) => (
          <a
            href={`/tags/${tag.name}`}
            class="group inline-flex items-center gap-2 rounded-full border border-[#de8b3a]/40 bg-[#f7ecdf]/60 px-4 py-2 text-sm font-semibold text-[#8c4f0f] shadow-sm transition-all duration-200 hover:border-[#de8b3a]/80 hover:bg-[#f0e0c5] hover:brightness-[1.03] hover:shadow-[0_4px_14px_rgba(222,139,58,0.25)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#de8b3a]/60 dark:border-[#3fd3c6]/40 dark:bg-[#0e2e38]/70 dark:text-[#7dd8cf] dark:hover:border-[#3fd3c6]/80 dark:hover:bg-[#12404d] dark:hover:brightness-[1.04] dark:hover:text-[#b8f0ea] dark:hover:shadow-[0_4px_14px_rgba(63,211,198,0.2)] dark:focus-visible:ring-[#3fd3c6]/60"
          >
            <span>{tag.name}</span>
            <span class="rounded-full bg-[#de8b3a]/20 px-2 py-0.5 text-xs font-bold text-[#7a4210] transition-colors duration-200 group-hover:bg-[#de8b3a]/35 dark:bg-[#3fd3c6]/15 dark:text-[#5bbdb5] dark:group-hover:bg-[#3fd3c6]/28 dark:group-hover:text-[#7ee8e0]">
              {tag.count}
            </span>
          </a>
        ))
      }
    </div>

    {
      allTags.length === 0 && (
        <p class="text-[#537884] dark:text-[#7caab2]">No tags found.</p>
      )
    }
  </div>
</Layout>
