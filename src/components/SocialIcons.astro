---
import { SOCIALS } from "@/consts";
import { Icon } from "astro-icon/components";
---

{
  SOCIALS.map((value) => (
    <a
      href={value.url}
      target="_blank"
      rel="noopener noreferrer"
      class="rounded-md p-1 text-[#97b8bf] transition-all duration-200 hover:scale-105 hover:text-[#f4c369] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-highlight-light/70 dark:text-[#7ca4ac] dark:hover:text-[#71e2d4] dark:focus-visible:ring-highlight-dark/70"
      aria-label={value.title}
      title={value.title}
    >
      <Icon name={value.icon} />
    </a>
  ))
}
