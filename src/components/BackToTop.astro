<button
  id="back-to-top"
  type="button"
  aria-label="Back to top"
  class="bg-interactive cyber-scanner fixed right-4 bottom-5 z-40 inline-flex scale-95 items-center gap-2 rounded-full border border-highlight-light/60 px-3 py-2 text-sm font-heading font-bold tracking-[0.18em] text-[#8d5317] opacity-0 shadow-[0_18px_35px_rgba(10,30,42,0.16)] transition-all duration-300 pointer-events-none sm:right-6 sm:bottom-6 dark:border-highlight-dark/70 dark:bg-[#0b2430]/92 dark:text-[#8ce0d8] dark:shadow-[0_20px_40px_rgba(2,10,18,0.42)]"
>
  <span
    aria-hidden="true"
    class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-current/40 bg-white/65 dark:bg-[#102f39]"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      class="h-4 w-4"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 18V6m0 0-5 5m5-5 5 5" />
    </svg>
  </span>
  <span class="hidden sm:inline">TOP</span>
</button>

<script>
  const button = document.getElementById("back-to-top");

  const syncBackToTopVisibility = () => {
    if (!(button instanceof HTMLButtonElement)) return;

    const shouldShow = window.scrollY > window.innerHeight * 0.8;

    button.classList.toggle("pointer-events-none", !shouldShow);
    button.classList.toggle("opacity-0", !shouldShow);
    button.classList.toggle("scale-95", !shouldShow);
    button.classList.toggle("opacity-100", shouldShow);
    button.classList.toggle("scale-100", shouldShow);
  };

  const handleBackToTopClick = () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  };

  if (button instanceof HTMLButtonElement) {
    button.addEventListener("click", handleBackToTopClick);
  }

  syncBackToTopVisibility();
  window.addEventListener("scroll", syncBackToTopVisibility, { passive: true });
  document.addEventListener("astro:after-swap", syncBackToTopVisibility);
</script>