---
import { Icon } from "astro-icon/components";

interface Props {
  href: string;
  icon: string;
  text: string;
  target?: string;
}

const { href, icon, text, target = "_self" } = Astro.props;
const rel = target === "_blank" ? "noopener noreferrer" : undefined;
---

<a
  href={href}
  target={target}
  rel={rel}
  class="font-heading link-highlight cyber-link cyber-scanner group relative flex items-center rounded-md px-2 py-1 font-bold tracking-wide text-[#123744] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-highlight-light/70 dark:text-[#b8d9de] dark:focus-visible:ring-highlight-dark/70"
>
  <Icon
    name={icon}
    class="mr-2 text-lg text-[#bf7226] transition-colors duration-200 group-hover:text-highlight-light dark:text-[#58cfc2] dark:group-hover:text-[#78eee0]"
  />
  {text}
</a>
