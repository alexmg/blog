---

---

<span
  class="terminal-prompt select-none"
  aria-hidden="true"
  data-terminal-prompt
>
  <span class="text-highlight-light dark:text-[#f4cb87]">~</span>
  <span class="text-[#537884] dark:text-[#9cc2c9]">/</span>
  <span class="text-[#0d6e69] dark:text-[#71e2d4]">alex</span>
  <span class="mx-1 text-[#c08b3f] dark:text-[#dcb047]">❯</span>
</span>

<script is:inline>
  const startTerminalPromptAnimation = () => {
    for (const prompt of document.querySelectorAll("[data-terminal-prompt]")) {
      prompt.classList.remove("prompt-live");
      void prompt.offsetWidth;
      prompt.classList.add("prompt-live");
    }
  };

  const scheduleTerminalPromptAnimation = () => {
    window.setTimeout(() => {
      requestAnimationFrame(startTerminalPromptAnimation);
    }, 240);
  };

  if (document.readyState === "complete") {
    scheduleTerminalPromptAnimation();
  } else {
    window.addEventListener("load", scheduleTerminalPromptAnimation, {
      once: true,
    });
  }
</script>

<style>
  @reference "../styles/global.css";

  .terminal-prompt {
    @apply relative isolate mr-2 inline-flex items-center overflow-hidden;
    white-space: nowrap;
  }

  .terminal-prompt::before {
    content: none;
  }

  .terminal-prompt > span {
    display: inline-block;
  }

  .terminal-prompt.prompt-live {
    animation: prompt-shell 0.92s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .terminal-prompt.prompt-live::before {
    content: "";
    position: absolute;
    inset: -0.12em -0.18em;
    background: linear-gradient(
      100deg,
      transparent 18%,
      color-mix(in srgb, var(--color-highlight-light) 34%, transparent) 42%,
      color-mix(in srgb, var(--color-highlight-dark) 42%, transparent) 54%,
      transparent 78%
    );
    opacity: 0;
    pointer-events: none;
    transform: translateX(-145%) skewX(-18deg);
    animation: prompt-scan 0.74s ease-out 0.12s forwards;
  }

  .terminal-prompt.prompt-live > span {
    text-shadow:
      -0.06em 0 0
        color-mix(in srgb, var(--color-highlight-light) 45%, transparent),
      0.06em 0 0
        color-mix(in srgb, var(--color-highlight-dark) 40%, transparent);
    will-change: transform, filter, opacity;
    animation: prompt-glyph 0.62s cubic-bezier(0.2, 0.9, 0.2, 1) both;
  }

  .terminal-prompt.prompt-live > span:nth-child(1) {
    animation-delay: 0.02s;
  }

  .terminal-prompt.prompt-live > span:nth-child(2) {
    animation-delay: 0.12s;
  }

  .terminal-prompt.prompt-live > span:nth-child(3) {
    animation-delay: 0.22s;
  }

  .terminal-prompt.prompt-live > span:nth-child(4) {
    animation-delay: 0.32s;
  }

  @keyframes prompt-shell {
    0% {
      filter: saturate(0.82) brightness(0.94);
    }

    55% {
      filter: saturate(1.08) brightness(1.02);
    }

    100% {
      filter: none;
    }
  }

  @keyframes prompt-glyph {
    0% {
      transform: translateX(-0.045em) skewX(-12deg) scaleX(0.95);
      filter: blur(1.6px);
    }

    36% {
      transform: translateX(0.035em) skewX(7deg) scaleX(1.03);
      filter: blur(0.45px);
    }

    72% {
      transform: translateX(-0.012em) skewX(-2deg) scaleX(0.99);
      filter: blur(0);
      text-shadow:
        -0.03em 0 0
          color-mix(in srgb, var(--color-highlight-light) 20%, transparent),
        0.03em 0 0
          color-mix(in srgb, var(--color-highlight-dark) 18%, transparent);
    }

    100% {
      transform: none;
      filter: none;
      text-shadow: none;
    }
  }

  @keyframes prompt-scan {
    0% {
      opacity: 0;
      transform: translateX(-145%) skewX(-18deg);
    }

    30% {
      opacity: 0.85;
    }

    100% {
      opacity: 0;
      transform: translateX(145%) skewX(-18deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .terminal-prompt {
      filter: none;
      animation: none;
    }

    .terminal-prompt::before {
      animation: none;
      content: none;
    }

    .terminal-prompt > span {
      animation: none;
      transform: none;
      filter: none;
      text-shadow: none;
    }
  }
</style>
