---
interface Props {
  tags?: string[];
}

const { tags } = Astro.props;
---

{
  tags && tags.length > 0 && (
    <>
      <span class="mx-2">•</span>
      <div class="flex flex-wrap gap-2">
        {tags.map((t) => (
          <a
            href={`/tags/${t}`}
            class="rounded-full border border-highlight-light/45 bg-[#f7ecdf]/70 px-2.5 py-1 text-xs font-semibold tracking-wide text-[#975815] transition-all duration-200 hover:bg-[#f6e3cb] hover:brightness-[1.03] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-highlight-light/70 dark:border-highlight-dark/45 dark:bg-[#12313b]/75 dark:text-[#8de2d9] dark:hover:bg-[#17414d] dark:hover:brightness-[1.04] dark:focus-visible:ring-highlight-dark/70"
          >
            {t}
          </a>
        ))}
      </div>
    </>
  )
}
