---
import { SITE } from "@/consts";

// Get current year for the copyright
const currentYear = new Date().getFullYear();
---

<footer
  class="relative mt-auto border-t border-[#7ba2ac]/35 bg-[#f6fafb]/80 dark:border-[#1f4856] dark:bg-[#081b24]/85"
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-[linear-gradient(to_right,transparent,rgba(222,139,58,0.7),transparent)]"
  ></div>
  <div class="container-base py-6">
    <p class="text-center text-sm text-[#456a76] dark:text-[#7fa7b0]">
      © 2008-{currentYear}
      {SITE.title}. All rights reserved.
    </p>
  </div>
</footer>
