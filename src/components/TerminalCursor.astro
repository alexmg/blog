---
interface Props {
  classes?: string;
}

const { classes } = Astro.props;
---

<span class:list={["terminal-cursor", classes]} aria-hidden="true"></span>

<style>
  .terminal-cursor {
    @apply inline-block h-[0.85em] w-[0.55em] translate-y-[0.1em] bg-[#de8b3a] align-baseline;
    margin-left: 0.15em;
    box-shadow: 0 0 8px rgba(222, 139, 58, 0.4);
    animation:
      blink 1.2s step-end infinite,
      glitch 8s step-end infinite;
  }

  :global(.dark) .terminal-cursor {
    @apply bg-[#3fd3c6];
    box-shadow: 0 0 10px rgba(63, 211, 198, 0.5);
  }

  @keyframes blink {
    from,
    to {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  @keyframes glitch {
    0%,
    94%,
    96%,
    98%,
    100% {
      transform: translateY(0.1em) scaleX(1) skew(0deg);
      opacity: 1;
    }
    95% {
      transform: translateY(0.1em) scaleX(1.3) skew(10deg);
      opacity: 0.75;
    }
    97% {
      transform: translateY(0.1em) scaleX(0.8) skew(-10deg);
      opacity: 0.85;
    }
    99% {
      transform: translateY(0.1em) scaleX(1.1) skew(5deg);
      opacity: 0.7;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .terminal-cursor {
      animation: blink 1.5s step-end infinite;
    }
  }
</style>
