---
import { SITE } from "@/consts";
import SocialIcons from "./SocialIcons.astro";
import MenuItem from "./MenuItem.astro";
import ThemeToggle from "./ThemeToggle.astro";
import MenuToggle from "./MenuToggle.astro";
---

<header class="relative z-10 w-full border-b border-[#7ba2ac]/35 dark:border-[#1f4856]">
  <!-- Banner -->
  <div
    class="h-52 w-full bg-cover bg-center"
    style="background-image: url('/banner.webp');"
  >
    <div
      class="relative flex h-full w-full flex-col items-center justify-center bg-[linear-gradient(to_bottom,rgba(5,14,20,0.2),rgba(5,14,20,0.56))]"
    >
      <!-- Site title -->
      <a href="/" aria-label={`${SITE.title} – home`}>
        <p
          class="font-heading text-3xl font-extrabold tracking-[0.05em] text-[#f8f2df] drop-shadow-[0_3px_14px_rgba(0,0,0,0.45)] transition-colors duration-200 hover:text-[#f8ca76] sm:text-4xl"
        >
          {SITE.title}
        </p>
      </a>
      <!-- Social icons -->
      <div
        class="mt-3 flex items-center space-x-3 text-xl text-[#b2ccd1] sm:text-2xl"
      >
        <SocialIcons />
      </div>
    </div>
  </div>
  <!-- Logo -->
  <div class="relative mx-auto max-w-7xl">
    <div class="absolute left-4 z-30 -translate-y-[62%] transform sm:left-6 lg:left-8">
      <a href="/" aria-hidden="true" tabindex="-1" class="cursor-pointer">
        <img
          src="/logo.webp"
          alt={SITE.title}
          class="h-32 w-32 rounded-full border-4 border-[#f4cb87] object-cover shadow-[0_0_0_4px_rgba(13,38,48,0.3),0_20px_35px_rgba(7,24,34,0.35)] dark:border-highlight-dark"
        />
      </a>
    </div>
  </div>
  <!-- Navigation bar -->
  <div class="group/nav-rail relative overflow-hidden border-t border-[#7ba2ac]/12 bg-[#f3f8f9]/52 shadow-[0_12px_24px_rgba(10,30,42,0.06)] backdrop-blur-md dark:border-[#183947]/90 dark:bg-[linear-gradient(90deg,rgba(6,20,27,0.94),rgba(8,26,35,0.9),rgba(6,20,27,0.94))] dark:shadow-[0_16px_34px_rgba(1,8,14,0.42)]">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 hidden dark:block">
      <div class="absolute top-[-16%] right-[2%] h-20 w-64 bg-[radial-gradient(circle,rgba(222,139,58,0.11)_0%,rgba(222,139,58,0.045)_34%,rgba(222,139,58,0)_74%)] opacity-20 blur-2xl transition-opacity duration-250 group-hover/nav-rail:opacity-70 group-focus-within/nav-rail:opacity-70"></div>
      <div class="absolute inset-y-0 right-[6%] w-36 bg-[linear-gradient(90deg,rgba(222,139,58,0),rgba(222,139,58,0.04),rgba(222,139,58,0))] opacity-12 blur-xl transition-opacity duration-250 group-hover/nav-rail:opacity-50 group-focus-within/nav-rail:opacity-50"></div>
      <div class="absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,rgba(63,211,198,0),rgba(63,211,198,0.2),rgba(222,139,58,0.18),rgba(63,211,198,0))] opacity-42 transition-opacity duration-250 group-hover/nav-rail:opacity-100 group-focus-within/nav-rail:opacity-100"></div>
    </div>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-x-[14%] -top-10 h-24 bg-[radial-gradient(ellipse_at_center,rgba(222,139,58,0.16)_0%,rgba(63,211,198,0.08)_38%,rgba(222,139,58,0)_76%)] opacity-0 blur-2xl transition-all duration-300 group-hover/nav-rail:translate-y-1 group-hover/nav-rail:opacity-55 group-focus-within/nav-rail:translate-y-1 group-focus-within/nav-rail:opacity-65 dark:bg-[radial-gradient(ellipse_at_center,rgba(63,211,198,0.22)_0%,rgba(222,139,58,0.12)_38%,rgba(63,211,198,0)_76%)]"
    ></div>
    <div class="container-base relative z-10 flex items-center justify-between py-4">
      <div class="flex-1"></div>

      <!-- Mobile menu buttons -->
      <div class="flex items-center space-x-3 sm:hidden">
        <ThemeToggle id="theme-toggle-mobile" />
        <MenuToggle id="menu-toggle" />
      </div>

      <!-- Desktop navigation -->
      <div class="hidden items-center space-x-6 sm:flex">
        <nav aria-label="Main navigation" class="flex space-x-6">
          <MenuItem href="/posts" icon="post" text="Posts" />
          <MenuItem href="/tags" icon="tag" text="Tags" />
          <MenuItem href="/rss.xml" icon="rss" text="RSS" target="_blank" />
        </nav>
        <ThemeToggle id="theme-toggle" />
      </div>
    </div>

    <!-- Mobile navigation menu (hidden by default) -->
    <div
      id="mobile-menu"
      class="hidden border-t border-[#7ba2ac]/25 bg-[#f7fbfc]/95 px-4 py-4 sm:hidden dark:border-[#1f4856] dark:bg-[#0a1e27]/95"
    >
      <nav aria-label="Main navigation" class="flex flex-col space-y-6">
        <MenuItem href="/posts" icon="post" text="Posts" />
        <MenuItem href="/tags" icon="tag" text="Tags" />
        <MenuItem href="/rss.xml" icon="rss" text="RSS" target="_blank" />
      </nav>
    </div>
  </div>

  <script>
    // Mobile menu toggle functionality
    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");

    if (menuToggle && mobileMenu) {
      menuToggle.addEventListener("click", () => {
        mobileMenu.classList.toggle("hidden");
        const isExpanded = !mobileMenu.classList.contains("hidden");
        menuToggle.setAttribute("aria-expanded", String(isExpanded));
        menuToggle.setAttribute(
          "aria-label",
          isExpanded ? "Close navigation" : "Open navigation",
        );
      });
    }
  </script>
</header>
