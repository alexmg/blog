---
interface Props {
  id: string;
}
const { id } = Astro.props;
---

<button
  id={id}
  class="bg-interactive cyber-scanner cyber-pulse cursor-pointer p-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-highlight-light/70 dark:focus-visible:ring-highlight-dark/70"
  aria-label="Toggle menu"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="h-6 w-6 text-[#43636d] dark:text-[#8ce0d8]"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M4 6h16M4 12h16M4 18h16"></path>
  </svg>
</button>
