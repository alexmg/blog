---
interface Props {
  id: string;
}
const { id } = Astro.props;
---

<button
  id={id}
  type="button"
  aria-controls="mobile-menu"
  aria-expanded="false"
  aria-label="Toggle menu"
  class="bg-interactive cyber-scanner cyber-pulse group cursor-pointer p-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-highlight-light/70 dark:focus-visible:ring-highlight-dark/70"
>
  <span class="sr-only">Toggle menu</span>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="h-6 w-6 text-[#9d5f1d] transition-transform duration-200 group-hover:rotate-6 dark:text-[#62d3c7] dark:group-hover:-rotate-6"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M4 6h16M4 12h16M4 18h16"></path>
  </svg>
</button>
